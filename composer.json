{
    "name": "sparkphp-br/installer",
    "description": "Instalador global do SparkPHP",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.3",
        "symfony/console": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "SparkPhp\\Installer\\": "src/"
        }
    },
    "bin": [
        "bin/sparkphp"
    ],
    "scripts": {
        "post-install-cmd": ["@php bin/sparkphp path:setup"],
        "post-update-cmd":  ["@php bin/sparkphp path:setup"]
    },
    "minimum-stability": "stable"
}
